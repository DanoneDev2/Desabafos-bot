# ==========================
# Discord
# ==========================
TOKEN_DISCORD=
CANAL_DESABAFOS=

# ==========================
# IA - Google Gemini (prioridade 1)
# ==========================
API_KEY_GEMINI=
MODEL_NAME=gemini-1.5-flash

# ==========================
# IA - Groq (fallback, prioridade 2)
# ==========================
API_KEY_GROQ=
GROQ_MODEL_NAME=llama-3.1-70b-versatile

# ==========================
# Comportamento da IA
# ==========================
TEMPERATURE=0.9

# ==========================
# Memória / Gerenciamento de contexto
# ==========================
# Quantas rodadas (pergunta+resposta) ficam guardadas por usuário.
MAX_HISTORY=10
# Quantas rodadas são de fato enviadas à IA a cada chamada (0 = usar MAX_HISTORY).
CONTEXTO_MAXIMO_ENVIO=0
# Tamanho máximo (em caracteres) do resumo automático de mensagens antigas.
RESUMO_MAX_CARACTERES=800
# Após quanto tempo sem atividade (segundos) o histórico de um usuário é liberado da RAM.
MEMORIA_INATIVIDADE_MAX_SEGUNDOS=21600

# ==========================
# Segurança / Anti-spam
# ==========================
COOLDOWN_SEGUNDOS=5
TAMANHO_MAXIMO_MENSAGEM=1500

# ==========================
# Fila assíncrona de requisições à IA
# ==========================
FILA_IA_TAMANHO_MAXIMO=50

# ==========================
# Retry / Backoff exponencial
# ==========================
RETRY_MAX_TENTATIVAS=3
RETRY_BACKOFF_BASE_SEGUNDOS=1.0
RETRY_BACKOFF_TETO_SEGUNDOS=20.0

# ==========================
# Circuit Breaker (por provedor de IA)
# ==========================
CIRCUIT_BREAKER_FALHAS_CONSECUTIVAS=3
CIRCUIT_BREAKER_TIMEOUT_SEGUNDOS=60

# ==========================
# SQLite (blacklist, estatísticas, configurações persistentes)
# ==========================
DB_PATH=dados/desabafos.db
DB_BACKUP_DIR=dados/backups
DB_BACKUP_MAX=5
DB_BACKUP_INTERVALO_HORAS=24

# ==========================
# Limpeza automática / Logs
# ==========================
LIMPEZA_INTERVALO_HORAS=6
LOGS_RETENCAO_DIAS=7

# ==========================
# Watchdog (monitor interno)
# ==========================
WATCHDOG_INTERVALO_SEGUNDOS=30
